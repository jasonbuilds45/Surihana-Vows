# ─────────────────────────────────────────────────────────────────────────────
# Surihana Vows — Environment Variable Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Personal access token — used ONLY by scripts/setup-database.ts to call the
# Supabase Management API. Not used at runtime by the Next.js application.
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=YOUR_SUPABASE_PERSONAL_ACCESS_TOKEN

# ── Site URL ─────────────────────────────────────────────────────────────────
# Production: https://yourdomain.com  |  Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Livestream ───────────────────────────────────────────────────────────────
# YouTube embed URL, e.g. https://www.youtube.com/embed/LIVE_VIDEO_ID
# Leave blank to use the default placeholder.
NEXT_PUBLIC_LIVESTREAM_URL=

# ── Auth Secret ──────────────────────────────────────────────────────────────
# REQUIRED in production. Must be a cryptographically random string, 32+ chars.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this value invalidates all existing sessions.
AUTH_SECRET=REPLACE_WITH_A_SECURE_RANDOM_64_CHAR_HEX_STRING

# ── Family Login Credentials ─────────────────────────────────────────────────
# Used for demo/local fallback login when Supabase family_users table is empty.
# REQUIRED in production — do NOT use the defaults below.
# The password here is compared directly (no hashing) for the fallback account.
FAMILY_LOGIN_EMAIL=family@yourweddingdomain.com
FAMILY_LOGIN_PASSWORD=REPLACE_WITH_A_STRONG_UNIQUE_PASSWORD

# ── Admin Login Credentials ───────────────────────────────────────────────────
# Same as above but for the admin role fallback account.
ADMIN_LOGIN_EMAIL=admin@yourweddingdomain.com
ADMIN_LOGIN_PASSWORD=REPLACE_WITH_A_STRONG_UNIQUE_PASSWORD

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Used to deliver magic sign-in links to family users.
# Get your API key at https://resend.com — free tier covers up to 100 emails/day.
#
# RESEND_API_KEY   — your Resend secret key (starts with re_...)
# EMAIL_FROM       — the verified sender address in your Resend domain.
#                    Must match a domain you've verified with Resend.
#                    Example: noreply@surihana.vows
#
# If RESEND_API_KEY is not set:
#   • In development: the magic link is logged to the console instead of sent.
#   • In production: email delivery fails and the error is logged server-side.
#     Users will not receive sign-in links until this is configured.
RESEND_API_KEY=
EMAIL_FROM=noreply@yourweddingdomain.com

# ── Theme ─────────────────────────────────────────────────────────────────────
# Controls the visual palette of the entire platform.
# Set in app/layout.tsx via data-theme="<value>" on <html>.
# Available values: warm (default) | minimal | jewel
# This variable is informational — it is not read at runtime by Next.js.
# Change it by editing app/layout.tsx and app/globals.css (see themes/README.md).
# SURIHANA_THEME=warm
